modules = ["python-3.11", "nodejs-20"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pip install -q -r requirements.txt"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd web && npm install && npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m src.speech_to_video.api.server"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[nix]
channel = "stable-23_11"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "pip install -r requirements.txt && cd web && npm install && npm run build"]
run = ["python", "-m", "src.speech_to_video.api.server"]
