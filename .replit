modules = ["nodejs-20", "python-3.11"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Web UI"

[[workflows.workflow]]
name = "Web UI"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pip install -r requirements.txt && cd web && npm install && npm run build && cd .. && python -m src.speech_to_video.api.server"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[nix]
channel = "stable-23_11"

[deployment]
deploymentTarget = "autoscale"
run = ["python", "-m", "src.speech_to_video.api.server"]
build = ["bash", "-c", "pip install -r requirements.txt && cd web && npm install && npm run build"]
